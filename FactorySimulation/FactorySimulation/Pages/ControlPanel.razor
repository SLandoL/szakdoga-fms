        </div>
        <!--5.sor-->
        <div class="row justify-content-center">
            <div class="col text-center">
                @if (!ControlPanelViewModel.RendszerButton && !ControlPanelViewModel.PauseButton && ControlPanelViewModel.Ready)
                {
                    @if (ControlPanelViewModel.KommKozElectroKommButton)
                    {
                        <button class="btn button_panel_error" @onclick="() => ControlPanelVM.PostKommKozElectroKommError()">Komm. központ árammérő meghibásodása</button>
                    }
                    else
                    {
                        <button class="btn button_panel" @onclick="() => ControlPanelVM.PostKommKozElectroKommError()">Komm. központ árammérő meghibásodása</button>

