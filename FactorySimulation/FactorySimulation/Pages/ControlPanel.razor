            </div>
            <div class="col text-center">
                @if (!ControlPanelViewModel.RendszerButton && !ControlPanelViewModel.PauseButton && ControlPanelViewModel.Ready)
                {
                    @if (ControlPanelViewModel.TartalyElectroKommButton)
                    {
                        <button class="btn button_panel_error" @onclick="() => ControlPanelVM.PostTartalyElectroKommError()">Tartály árammérő meghibásodása</button>
                    }
                    else
