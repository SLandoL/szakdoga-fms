            </div>
            <div class="col text-center">
                @if (!ControlPanelViewModel.RendszerButton && !ControlPanelViewModel.PauseButton && ControlPanelViewModel.Ready)
                {
                    @if (ControlPanelViewModel.RFIDButton)
                    {
                        <button class="btn button_panel_error" @onclick="() => ControlPanelVM.PostRFIDError()">RFID olvasó meghibásodása</button>
                    }
                    else
                    {
                        <button class="btn button_panel" @onclick="() => ControlPanelVM.PostRFIDError()">RFID olvasó meghibásodása</button>
                    }
                }
                else
                {
                    @if (ControlPanelViewModel.RFIDButton)
                    {
