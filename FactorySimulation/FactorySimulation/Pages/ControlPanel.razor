</body>

@code {
    private async void WakeUpOnClick()
    {
        await ControlPanelVM.PostWakeUp();
        StateHasChanged();
    }

    protected async override Task OnInitializedAsync()
    {
        try
        {
            await ControlPanelVM.GetDiagnoses();
            StateHasChanged();
        }
        catch (Exception)
        {
            Console.WriteLine("Nem sikerült lekérni az adatokat");
        }
        await ControlPanelVM.PostLED(ControlPanelViewModel.LEDColor);
        if (ControlPanelVM.CarCanGo())
        {
            await ControlPanelVM.PostCarSpeed(ControlPanelViewModel.CarSpeed);
        }
    }
}
