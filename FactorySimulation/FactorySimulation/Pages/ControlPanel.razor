                    }
                    else
                    {
                        <button class="btn button_panel" disabled>Tartály áramellátásának meghibásodása</button>

                    }
                }
            </div>
            <div class="col text-center">
                @if (!ControlPanelViewModel.RendszerButton && !ControlPanelViewModel.PauseButton && ControlPanelViewModel.Ready)
                {
                    @if (ControlPanelViewModel.KocsiElectroButton)
                    {
                        <button class="btn button_panel_error" @onclick="() => ControlPanelVM.PostKocsiElectroError()">Kocsi áramellátásának meghibásodása</button>
