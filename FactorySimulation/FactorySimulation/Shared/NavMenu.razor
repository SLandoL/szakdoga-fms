@using Data

@inject MQTTService mqttService

<svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
    <symbol id="exclamation-triangle-fill" fill="currentColor" viewBox="0 0 16 16">
        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
    </symbol>
</svg>

<div class="top-row pl-4 navbar navbar-dark" id="corner_navbar">
    <a class="navbar-brand tilte_shadow" href=""><img class="shadow_img mr-1 p-1" width="30" height="30" src="../Images/cropped-logo_kicsi-2.png" alt="Ipar4 Logo" /> Factory Simulation</a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Home
            </NavLink>
        </li>
        <AuthorizeView>
            <Authorized>
                <li class="nav-item px-3" @onclick="ToggleNavMenu">
                    <NavLink class="nav-link" href="ControlPanel">
                        <span class="oi oi-grid-three-up" aria-hidden="true"></span> Control Panel
                    </NavLink>
                </li>
                <li class="nav-item px-3" @onclick="ToggleNavMenu">
                    <NavLink class="nav-link" href="DigitalFactory">
                        <span class="fas fa-industry" style="font-size:large; width:32px;"></span> Digital Factory
                    </NavLink>
                </li>
                <li class="broker nav-item px-3" @onclick="async() => await ReconnectAndSpinner()">
                    <NavLink class="nav-link" style="cursor: pointer">
                        <span class="invis_button d-inline-flex align-items-center">
                            @if (isLoading)
                            {
                                <span class="ml-1 mr-2"><SpinLoader IsLoading="isLoading" Spinner="SpinnerType.Chase" Size="17.6px" Color="#ffffff"></SpinLoader></span>
                            }
                            else
                            {
                                <span class="oi oi-reload" style="color: #ffffff"></span>
                            }
                            Reconnect to MQTT
                        </span>
                    </NavLink>
                </li>
            </Authorized>
        </AuthorizeView>
    </ul>
</div>

@if (mqttService.alert == ProfileMessages.MQTTISREACHABLE)
{
    <div class="alert alert-success alert-dismissible fade show align-bottom text-center mr-2 ml-2 alert_position" id="alert_size" role="alert">
        <svg class="bi flex-shrink-0 me-2" width="16" height="16" role="img" aria-label="Success:">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
        </svg>
        <div>
            Elérhető az MQTT Broker!
        </div>
        <button type="button" class="close" @onclick="DismissAlert" aria-label="close"><span aria-hidden="true">&times;</span></button>
    </div>
}
else if (mqttService.alert == ProfileMessages.MQTTNOTUP)
{
    <div class="alert alert-danger alert-dismissible fade show align-bottom text-center mr-2 ml-2 alert_position" id="alert_size" role="alert">
        <svg class="bi flex-shrink-0 me-2" width="16" height="16" role="img" aria-label="Danger:"><use xlink:href="#exclamation-triangle-fill" /></svg>
        <div>
            Nem érhető el az MQTT Broker!
        </div>
        <button type="button" class="close" @onclick="DismissAlert" aria-label="close"><span aria-hidden="true">&times;</span></button>
    </div>
}

@code {
    private bool collapseNavMenu = true;
    public bool isLoading = false;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void DismissAlert()
    {
        mqttService.alert = ProfileMessages.NULL;
        StateHasChanged();
    }

    private async Task ReconnectAndSpinner()
    {
        isLoading = true;
        StateHasChanged();
        await mqttService.ConnectMQTT();
        isLoading = false;
        StateHasChanged();
    }
}
