@page "/dashboard"

@using Data
@using Model
@using ViewModels
@inject DashboardViewModel dashboardVM
@inject FaultSearch faultSearch
@inject IStringLocalizer<App> Localizer

<body class="py-0" style="background-color: transparent">
    <div class="container_dash mr-0 mt-0 pt-0">
        <div class="header1_dash justify-content-center">@Localizer["Gyártósor"]</div>
        <div class="header2_dash justify-content-center">@Localizer["Áramellátás"]</div>

        <div class="content1_dash">
            @foreach (FaultButton button in ProductionFaults)
            {
                FaultButtonView view = CreateFaultButtonView(button);
                <button type="button"
                        class="fault_card @view.CssClass m-2"
                        style="@view.InlineStyle"
                        title="@view.Tooltip">
                    <span class="fault_card_prefix">@view.Prefix</span>
                    <span class="fault_card_text">@view.DisplayName</span>
                    <span class="fault_card_state">@view.StatusText</span>
                </button>
            }
        </div>

        <div class="content2_dash">
            @foreach (FaultButton button in PowerFaults)
            {
                FaultButtonView view = CreateFaultButtonView(button);
                <button type="button"
                        class="fault_card @view.CssClass m-2"
                        style="@view.InlineStyle"
                        title="@view.Tooltip">
                    <span class="fault_card_prefix">@view.Prefix</span>
                    <span class="fault_card_text">@view.DisplayName</span>
                    <span class="fault_card_state">@view.StatusText</span>
                </button>
            }
        </div>

        <div class="header3_dash justify-content-center">@Localizer["Kommunikáció"]</div>

        <div class="content3_dash mb-2">
            @foreach (FaultButton button in CommunicationFaults)
            {
                FaultButtonView view = CreateFaultButtonView(button);
                <button type="button"
                        class="fault_card @view.CssClass m-2"
                        style="@view.InlineStyle"
                        title="@view.Tooltip">
                    <span class="fault_card_prefix">@view.Prefix</span>
                    <span class="fault_card_text">@view.DisplayName</span>
                    <span class="fault_card_state">@view.StatusText</span>
                </button>
            }
        </div>

        <div class="rfid_panel">
            <div class="rfid_panel_title">RFID diagnosztika</div>
            <div class="rfid_panel_grid">
                <div class="rfid_panel_item">
                    <span class="rfid_label">ESP kapcsolat</span>
                    <span class="rfid_value">@FormatOnline(dashboardVM.RfidStatus.EspOnline)</span>
                    <span class="rfid_subvalue">Utolsó heartbeat: @FormatRelativeTime(dashboardVM.RfidStatus.LastHeartbeatUtc)</span>
                </div>
                <div class="rfid_panel_item">
                    <span class="rfid_label">Tank olvasó</span>
                    <span class="rfid_value">@FormatReaderStatus(dashboardVM.RfidStatus.TankReaderOk, dashboardVM.RfidStatus.TankReaderFresh)</span>
                    <span class="rfid_subvalue">Hibakód: @dashboardVM.RfidStatus.TankReaderErrorCode</span>
                </div>
                <div class="rfid_panel_item">
                    <span class="rfid_label">Raktár olvasó</span>
                    <span class="rfid_value">@FormatReaderStatus(dashboardVM.RfidStatus.WarehouseReaderOk, dashboardVM.RfidStatus.WarehouseReaderFresh)</span>
                    <span class="rfid_subvalue">Hibakód: @dashboardVM.RfidStatus.WarehouseReaderErrorCode</span>
                </div>
                <div class="rfid_panel_item">
                    <span class="rfid_label">Rakományegyezés</span>
                    <span class="rfid_value">@FormatCargoMatch(dashboardVM.RfidStatus)</span>
                    <span class="rfid_subvalue">Utolsó olvasás: @FormatRelativeTime(dashboardVM.RfidStatus.LastCargoReadUtc)</span>
                </div>
                <div class="rfid_panel_item rfid_panel_item_wide">
                    <span class="rfid_label">Olvasott rakományok</span>
                    <span class="rfid_value">Tank: @FormatCargoId(dashboardVM.RfidStatus.TankCargoId) | Raktár: @FormatCargoId(dashboardVM.RfidStatus.WarehouseCargoId)</span>
                    <span class="rfid_subvalue">@dashboardVM.RfidStatus.DiagnosticSummary</span>
                </div>
            </div>
        </div>

        <div class="footer_1 pb-1">
            <p class="work_icon pb-0 m-0">■ @Localizer["Elérhető"]</p>
            <p class="fault_icon m-0">■ @Localizer["Mért hiba"]</p>
            <p class="consequence_icon m-0">■ @Localizer["Következmény"]</p>
            <p class="rootfault_icon m-0">▲ @Localizer["Gyökér hiba"]</p>
        </div>
    </div>
</body>

@code {
    private readonly List<FaultButton> ProductionFaults = new List<FaultButton>
    {
        new FaultButton(FaultSearch.GyarSzalagSzenz.Name, "Szalag szenzorok"),
        new FaultButton(FaultSearch.GyarTartalySzenz.Name, "Tartály szenzorok"),
        new FaultButton(FaultSearch.GyarTargoncaSzenz.Name, "Kocsi szenzorok"),
        new FaultButton(FaultSearch.GyarRfidOlv.Name, "RFID olvasó")
    };

    private readonly List<FaultButton> PowerFaults = new List<FaultButton>
    {
        new FaultButton(FaultSearch.AramKommKozpont.Name, "Kommunikációs központ"),
        new FaultButton(FaultSearch.AramTartaly.Name, "Tartály"),
        new FaultButton(FaultSearch.AramKocsi.Name, "AVG Kocsi"),
        new FaultButton(FaultSearch.AramRendszer.Name, "Rendszer")
    };

    private readonly List<FaultButton> CommunicationFaults = new List<FaultButton>
    {
        new FaultButton(FaultSearch.KommKozpont.Name, "Kommunikációs központ"),
        new FaultButton(FaultSearch.KommKozpontUp.Name, "Kommunikációs központ elérhető"),
        new FaultButton(FaultSearch.KommKocsiEsp.Name, "Kocsi üvegek esp"),
        new FaultButton(FaultSearch.KommTartaly.Name, "Tartály esp"),
        new FaultButton(FaultSearch.KommKocsi.Name, "Kocsi elérhető"),
        new FaultButton(FaultSearch.KommRfidUp.Name, "Raktár RFID elérhető"),
        new FaultButton(FaultSearch.KommKommArammero.Name, "Komm. központ árammérő elérhető"),
        new FaultButton(FaultSearch.KommTartalyArammero.Name, "Tartály árammérő elérhető"),
        new FaultButton(FaultSearch.KommTargoncaArammero.Name, "Kocsi árammérő elérhetősége"),
        new FaultButton(FaultSearch.KommRendszer.Name, "Rendszer kommunikáció")
    };

    private FaultButtonView CreateFaultButtonView(FaultButton button)
    {
        FaultData fault = faultSearch.faultDatas.FirstOrDefault(item => item.Name == button.FaultName);
        FaultStatus status = fault?.FaultStatus ?? FaultStatus.WORKING;
        string statusText = GetStatusText(status);
        string displayName = GetDisplayName(button.DisplayName);
        string tooltip = fault == null
            ? $"{displayName}: nincs hozzá tartozó FaultData rekord, ezért WORKING-ként jelenik meg"
            : $"{displayName}: {statusText} ({button.FaultName})";

        return new FaultButtonView
        {
            FaultName = button.FaultName,
            DisplayName = displayName,
            Status = status,
            StatusText = statusText,
            Prefix = GetStatusPrefix(status),
            CssClass = GetButtonClass(status),
            InlineStyle = GetButtonInlineStyle(status),
            Tooltip = tooltip
        };
    }

    private string GetDisplayName(string displayName)
    {
        var localized = Localizer[displayName];
        return string.IsNullOrWhiteSpace(localized.Value) ? displayName : localized.Value;
    }

    private string GetButtonClass(FaultStatus status)
    {
        switch (status)
        {
            case FaultStatus.ROOTFAULT:
                return "fault_card_rootfault";
            case FaultStatus.FAULT:
                return "fault_card_fault";
            case FaultStatus.CONSEQUENCE:
                return "fault_card_consequence";
            default:
                return "fault_card_working";
        }
    }

    private string GetButtonInlineStyle(FaultStatus status)
    {
        switch (status)
        {
            case FaultStatus.ROOTFAULT:
                return "display:flex;visibility:visible;opacity:1;min-height:70px;align-items:center;justify-content:center;gap:.35rem;padding:.4rem .6rem;border-radius:30px;border:3px solid #111111;background:#ef4444;color:#111111;font-weight:bold;box-sizing:border-box;";
            case FaultStatus.FAULT:
                return "display:flex;visibility:visible;opacity:1;min-height:70px;align-items:center;justify-content:center;gap:.35rem;padding:.4rem .6rem;border-radius:30px;border:2px solid #b45309;background:#fbbf24;color:#111111;font-weight:bold;box-sizing:border-box;";
            case FaultStatus.CONSEQUENCE:
                return "display:flex;visibility:visible;opacity:1;min-height:70px;align-items:center;justify-content:center;gap:.35rem;padding:.4rem .6rem;border-radius:30px;border:3px dashed #1d4ed8;background:#bfdbfe;color:#0f172a;font-weight:bold;box-sizing:border-box;";
            default:
                return "display:flex;visibility:visible;opacity:1;min-height:70px;align-items:center;justify-content:center;gap:.35rem;padding:.4rem .6rem;border-radius:30px;border:2px solid #3f8f00;background:#adff2f;color:#111111;font-weight:bold;box-sizing:border-box;";
        }
    }

    private string GetStatusPrefix(FaultStatus status)
    {
        switch (status)
        {
            case FaultStatus.ROOTFAULT:
                return "▲";
            case FaultStatus.CONSEQUENCE:
                return "↳";
            default:
                return string.Empty;
        }
    }

    private string GetStatusText(FaultStatus status)
    {
        switch (status)
        {
            case FaultStatus.ROOTFAULT:
                return "Gyökér hiba";
            case FaultStatus.FAULT:
                return "Mért hiba";
            case FaultStatus.CONSEQUENCE:
                return "Következmény";
            default:
                return "Elérhető";
        }
    }

    private string FormatOnline(bool online)
    {
        return online ? "online" : "offline";
    }

    private string FormatReaderStatus(bool ok, bool fresh)
    {
        if (!fresh)
        {
            return "nincs friss adat";
        }

        return ok ? "működik" : "nem működik";
    }

    private string FormatCargoMatch(RfidStatus status)
    {
        if (!status.CargoMatchKnown)
        {
            return "nincs friss egyezési adat";
        }

        return status.CargoMatch ? "egyezik" : "nem egyezik";
    }

    private string FormatCargoId(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private string FormatRelativeTime(DateTime value)
    {
        if (value == DateTime.MinValue)
        {
            return "nincs adat";
        }

        TimeSpan age = DateTime.UtcNow - value;
        if (age.TotalSeconds < 1)
        {
            return "most";
        }

        if (age.TotalSeconds < 60)
        {
            return $"{Math.Floor(age.TotalSeconds)} mp";
        }

        if (age.TotalMinutes < 60)
        {
            return $"{Math.Floor(age.TotalMinutes)} perc";
        }

        return value.ToLocalTime().ToString("yyyy.MM.dd. HH:mm:ss");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await Task.Delay(1000);
            await dashboardVM.GetDiagnoses();
            await dashboardVM.PostLedRed();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private class FaultButton
    {
        public string FaultName { get; }
        public string DisplayName { get; }

        public FaultButton(string faultName, string displayName)
        {
            FaultName = faultName;
            DisplayName = displayName;
        }
    }

    private class FaultButtonView
    {
        public string FaultName { get; set; }
        public string DisplayName { get; set; }
        public FaultStatus Status { get; set; }
        public string StatusText { get; set; }
        public string Prefix { get; set; }
        public string CssClass { get; set; }
        public string InlineStyle { get; set; }
        public string Tooltip { get; set; }
    }
}
