@page
@model EnableAuthenticatorModel
@inject IStringLocalizer<App> Localizer
@{
    ViewData["Title"] = @Localizer["A hitelesítő alkalmazás konfigurálása"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h4>@ViewData["Title"]</h4>
<div>
    <p>@Localizer["A hitelesítő alkalmazás használatához kövesse az alábbi lépéseket:"]</p>
    <ol class="list">
        <li>
            <p>
                @Localizer["Töltsön le egy kétfaktoros hitelesítő alkalmazást, például a Microsoft Authenticator alkalmazást"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> @Localizer["és"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a> @Localizer["vagy"]
                @Localizer["Google Authenticator ehhez"]
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a> @Localizer["és"]
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
            </p>
        </li>
        <li>
            <p>@Localizer["Olvassa be a QR-kódot, vagy írja be ezt a kulcsot a kétfaktoros hitelesítő alkalmazásba. A szóközök nem számítanak"]<kbd>@Model.SharedKey</kbd>.</p>
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Html.Raw(@Model.AuthenticatorUri)"></div>
        </li>
        <li>
            <p>
                @Localizer["Miután beszkennelte a QR-kódot, vagy beírta a fenti kulcsot, a kétfaktoros hitelesítési alkalmazás egyedi kódot biztosít Önnek. Írja be a kódot az alábbi megerősítő mezőbe."]
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-group">
                            <label asp-for="Input.Code" class="control-label">@Localizer["Igazoló kód"]</label>
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" />
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary">@Localizer["Ellenőrzés"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script type="text/javascript" src="~/lib/qrcode.js"></script>
    <script type="text/javascript" src="~/js/qr.js"></script>
    <!--<partial name="_ValidationScriptsPartial" />-->
}
