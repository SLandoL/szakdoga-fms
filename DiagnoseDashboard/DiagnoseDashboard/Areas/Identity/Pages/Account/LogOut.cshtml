@page
@model LogoutModel
@inject IStringLocalizer<App> Localizer
@{
    ViewData["Title"] = @Localizer["Kijelentkezés"];
}

<header>
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity.IsAuthenticated)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark">@Localizer["Kattintson ide a kijelentkezéshez"]</button>
            </form>
        }
        else
        {
            <p>@Localizer["Sikeresen kijelentkezett az alkalmazásból."]</p>
        }
    }
</header>