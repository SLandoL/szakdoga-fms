@page
@model ExternalLoginModel
@inject IStringLocalizer<App> Localizer
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>
<h4 id="external-login-title">@Localizer["Társítja össze"] @Model.ProviderDisplayName @Localizer["-fiókját"]</h4>
<hr />

<p id="external-login-description" class="text-info">
    @Localizer["Sikeresen hitelesítette"] <strong>@Model.ProviderDisplayName @Localizer["fiókját"]</strong>.
    @Localizer["Kérjük, adja meg alább az oldal e-mail címét, majd kattintson a Regisztráció gombra a bejelentkezéshez."]
</p>

<div class="row">
    <div class="col-md-4">
        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">@Localizer["Bejelentkezés"]</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
